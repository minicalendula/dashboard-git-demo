{
  "datasets": [
    {
      "name": "top_drugs",
      "displayName": "상위 20 처방 약물",
      "queryLines": [
        "SELECT\n",
        "  drug_source_value AS drug_name,\n",
        "  COUNT(DISTINCT person_id) AS patient_count,\n",
        "  COUNT(drug_exposure_id) AS exposure_count\n",
        "FROM\n",
        "  cntdatabricksdemo_lakehouse01.cnt_healthcare_gold_omop.drug_exposure\n",
        "WHERE\n",
        "  drug_source_value IS NOT NULL\n",
        "  AND drug_source_value != ''\n",
        "GROUP BY\n",
        "  drug_source_value\n",
        "ORDER BY\n",
        "  exposure_count DESC\n",
        "LIMIT 20"
      ]
    },
    {
      "name": "top_conditions",
      "displayName": "상위 20 질병",
      "queryLines": [
        "SELECT\n",
        "  condition_source_value AS condition_name,\n",
        "  COUNT(DISTINCT person_id) AS patient_count,\n",
        "  COUNT(condition_occurrence_id) AS occurrence_count\n",
        "FROM\n",
        "  cntdatabricksdemo_lakehouse01.cnt_healthcare_gold_omop.condition_occurrence\n",
        "WHERE\n",
        "  condition_source_value IS NOT NULL\n",
        "  AND condition_source_value != ''\n",
        "GROUP BY\n",
        "  condition_source_value\n",
        "ORDER BY\n",
        "  occurrence_count DESC\n",
        "LIMIT 20"
      ]
    },
    {
      "name": "visit_trends",
      "displayName": "방문 추이",
      "config": {
        "dimensions": [
          {
            "expr": "YEAR(visit_start_date)",
            "name": "visit_year"
          },
          {
            "expr": "DATE_TRUNC('MONTH', visit_start_date)",
            "name": "visit_month"
          }
        ],
        "measures": [
          {
            "expr": "COUNT(DISTINCT visit_occurrence_id)",
            "name": "visit_count"
          },
          {
            "expr": "COUNT(DISTINCT person_id)",
            "name": "patient_count"
          }
        ],
        "source": "cntdatabricksdemo_lakehouse01.cnt_healthcare_gold_omop.visit_occurrence",
        "version": "1.1"
      }
    },
    {
      "name": "patient_demographics",
      "displayName": "환자 인구통계",
      "config": {
        "dimensions": [
          {
            "expr": "gender_source_value",
            "name": "gender"
          },
          {
            "expr": "race_source_value",
            "name": "race"
          },
          {
            "expr": "ethnicity_source_value",
            "name": "ethnicity"
          },
          {
            "expr": "age_group",
            "name": "age_group"
          },
          {
            "expr": "year_of_birth",
            "name": "birth_year"
          },
          {
            "expr": "birth_datetime",
            "name": "birth_date"
          }
        ],
        "measures": [
          {
            "expr": "COUNT(DISTINCT person_id)",
            "name": "patient_count"
          },
          {
            "expr": "SUM(is_deceased)",
            "name": "deceased_count"
          },
          {
            "expr": "AVG(age)",
            "name": "avg_age"
          }
        ],
        "source": "SELECT \n  p.person_id,\n  p.gender_source_value,\n  p.race_source_value,\n  p.ethnicity_source_value,\n  p.year_of_birth,\n  (2026 - p.year_of_birth) AS age,\n  CASE\n    WHEN (2026 - p.year_of_birth) < 18 THEN '0-17세'\n    WHEN (2026 - p.year_of_birth) BETWEEN 18 AND 29 THEN '18-29세'\n    WHEN (2026 - p.year_of_birth) BETWEEN 30 AND 39 THEN '30-39세'\n    WHEN (2026 - p.year_of_birth) BETWEEN 40 AND 49 THEN '40-49세'\n    WHEN (2026 - p.year_of_birth) BETWEEN 50 AND 59 THEN '50-59세'\n    WHEN (2026 - p.year_of_birth) BETWEEN 60 AND 69 THEN '60-69세'\n    WHEN (2026 - p.year_of_birth) >= 70 THEN '70세 이상'\n    ELSE '미상'\n  END AS age_group,\n  p.birth_datetime,\n  CASE WHEN d.person_id IS NOT NULL THEN 1 ELSE 0 END AS is_deceased\nFROM cntdatabricksdemo_lakehouse01.cnt_healthcare_gold_omop.person p LEFT JOIN cntdatabricksdemo_lakehouse01.cnt_healthcare_gold_omop.death d\n  ON p.person_id = d.person_id\n",
        "version": "1.1"
      }
    }
  ],
